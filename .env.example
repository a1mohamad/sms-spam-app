# Runtime inference settings.
THRESHOLD=0.5

# Optional artifact location.
# ARTIFACTS_DIR=/absolute/path/to/artifacts

# Local PostgreSQL initialization.
DB_PORT=5432
POSTGRES_DB=sms_spam
POSTGRES_USER=your_local_user
POSTGRES_PASSWORD=your_local_password

# Application database connection.
DATABASE_URL=postgresql+psycopg://your_local_user:your_local_password@localhost:5432/sms_spam

# Generate using Fernet.generate_key(); never commit the real key.
MESSAGE_ENCRYPTION_KEY=replace_with_a_generated_fernet_key